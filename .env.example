# ============================================================================
# AjarKit — Template environment (prd.md §4, diadaptasi ke Next.js)
# Salin file ini menjadi `.env.local` lalu isi nilainya:
#   cp .env.example .env.local
#
# ⚠️ JANGAN isi nilai rahasia di file ini — .env.example ikut ter-commit ke
#    git. Nilai asli hanya di .env.local (gitignored).
#
# Tanpa nilai di bawah, aplikasi otomatis berjalan dalam MODE MOCK
# (semua data lokal di browser). Begitu URL + anon key terisi dan SQL
# `supabase/migrations/*.sql` sudah dijalankan, aplikasi otomatis
# memakai Supabase (auth & data nyata).
# ============================================================================

# ---------- Frontend (publik — di-inline ke bundle browser) ----------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL aplikasi (dipakai utk redirect auth, mis. reset sandi)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analitik frontend (opsional)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Server (RAHASIA — jangan prefiks NEXT_PUBLIC_, jangan commit) ----------

# Service role (Project Settings → API) — dipakai webhook pembayaran & hapus akun.
SUPABASE_SERVICE_ROLE_KEY=

# AI nyata via OpenRouter (https://openrouter.ai/keys).
# Kosong = generator memakai konten contoh (simulasi).
OPENROUTER_API_KEY=
# Opsional — override routing model per mode kualitas (prd.md §9):
# OPENROUTER_MODEL_HEMAT=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_STANDAR=google/gemini-2.5-flash
# OPENROUTER_MODEL_TINGGI=google/gemini-2.5-pro
# OPENROUTER_MODEL_FALLBACK=google/gemini-2.5-flash

# Pembayaran nyata via Pakasir (https://pakasir.com → dashboard proyek).
# Kosong = alur pembayaran memakai simulasi QRIS/VA.
# Webhook: daftarkan {APP_URL}/api/payments/webhook di dashboard Pakasir →
# Edit Proyek → Webhook URL. (Lokal: butuh tunnel, mis. ngrok.)
PAKASIR_SLUG=
PAKASIR_API_KEY=

# Observability (opsional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=   # sama dgn SENTRY_DSN (utk error sisi browser)
POSTHOG_KEY=
